{
  "extends": "@weldsuite/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "paths": {
      "@weldsuite/db/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
