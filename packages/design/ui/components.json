{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@weldsuite/ui/components",
    "utils": "@weldsuite/ui/lib/utils",
    "hooks": "@weldsuite/ui/hooks",
    "lib": "@weldsuite/ui/lib",
    "ui": "@weldsuite/ui/components"
  },
   "registries": {
     "@shadcnblocks": {
      "url": "https://www.shadcnblocks.com/r/{name}",
      "headers": {
        "Authorization": "Bearer ${SHADCNBLOCKS_API_KEY}"
      }
    }
  }
}
