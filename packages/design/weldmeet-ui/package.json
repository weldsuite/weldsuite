{
  "name": "@weldsuite/weldmeet-ui",
  "license": "AGPL-3.0-only",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:ct:report": "playwright show-report"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "dependencies": {
    "@cloudflare/realtimekit": "^1.2.5",
    "@cloudflare/realtimekit-virtual-background": "^0.0.2",
    "@weldsuite/ui": "workspace:*",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "1.57.0",
    "@playwright/test": "1.57.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@weldsuite/eslint-config": "workspace:*",
    "@weldsuite/typescript-config": "workspace:*",
    "typescript": "^5.9.2"
  }
}
