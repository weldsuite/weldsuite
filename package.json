{
  "name": "weldsuite",
  "license": "AGPL-3.0-only",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:safe": "cross-env SKIP_PRISMA_GENERATE=true turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prisma:generate": "cd packages/database && npx prisma generate",
    "check:metadata": "node scripts/check-metadata.js",
    "secrets:put": "npx tsx scripts/secrets/put.ts",
    "secrets:sync": "npx tsx scripts/secrets/sync.ts",
    "secrets:dev": "npx tsx scripts/secrets/dev-vars.ts",
    "create:mobile-app": "node scripts/create-mobile-app.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "storybook": "turbo run dev --filter=storybook",
    "storybook:build": "turbo run storybook:build --filter=storybook"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/color": "^3.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash.groupby": "^4.6.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/minimatch": "^6.0.0",
    "@types/pg": "^8.15.5",
    "@weldsuite/eslint-config": "workspace:*",
    "@weldsuite/typescript-config": "workspace:*",
    "cross-env": "^10.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.9.16",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "use-sync-external-store": "^1.4.0",
      "@react-native-menu/menu": "2.0.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "sharp",
      "@parcel/watcher"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/lib-storage": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@faker-js/faker": "^10.1.0",
    "@neondatabase/serverless": "^1.0.1",
    "@stripe/stripe-js": "^7.6.1",
    "@uidotdev/usehooks": "^2.4.1",
    "color": "^4.2.3",
    "embla-carousel-autoplay": "^8.6.0",
    "emoji-picker-react": "^4.14.0",
    "expo": "~54.0.30",
    "firebase": "^12.1.0",
    "ioredis": "^5.7.0",
    "jotai": "^2.15.1",
    "jsonwebtoken": "^9.0.2",
    "lodash.groupby": "^4.6.0",
    "lodash.throttle": "^4.1.1",
    "postmark": "^4.0.5",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "stripe": "^18.3.0",
    "tunnel-rat": "^0.1.2",
    "zod": "^4.1.0"
  }
}
