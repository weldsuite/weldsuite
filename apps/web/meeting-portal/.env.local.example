# Platform app URL (for redirecting workspace members)
NEXT_PUBLIC_PLATFORM_URL=https://app.weldsuite.org

# Master database (for workspace/tenant resolution)
MASTER_DATABASE_URL=

# Neon API (for tenant DB connection strings)
NEON_API_KEY=

# Database encryption key (for encrypted fields)
DATABASE_ENCRYPTION_KEY=

# Cloudflare RealtimeKit (for video conferencing)
CF_ACCOUNT_ID=
CF_REALTIME_APP_ID=
CF_REALTIME_APP_SECRET=

# Realtime worker — used for in-meeting chat broadcasts
# Server-only URL (used by /api/meeting/[meetingId]/messages POST to publish)
REALTIME_WORKER_URL=https://realtime-test.weldsuite.org
# Shared secret with realtime-worker REALTIME_INTERNAL_SECRET binding
REALTIME_INTERNAL_SECRET=
# Public WebSocket URL the browser connects to for live chat updates
NEXT_PUBLIC_REALTIME_URL=https://realtime-test.weldsuite.org

# R2 (S3-compatible) — used to upload generated avatars for auto-created
# guest contacts. Must match the api-worker R2 settings so the URLs are
# interchangeable across workers.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=weldsuite-storage-test
R2_PUBLIC_URL=https://weldsuite-storage-test.weldsuite.org
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=