# WeldSuite Admin App (Next.js)

# Clerk (admin instance — NOT the platform Clerk)
#
# Clerk is the SOLE source of admin access. Sign-ups are disabled on this Clerk
# instance, so the console is invite-only — anyone who can sign in is a trusted
# admin. Grant elevated roles per user via Clerk public metadata:
#   User → Metadata → Public → { "role": "superadmin" }   (or "admin" / "viewer")
# Users with no role set default to "admin". Invite/remove admins in Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Master DB (Neon)
DATABASE_URL_MASTER=postgresql://...

# Optional: Neon API key + encryption key — only needed when tenant URLs
# aren't stored in master DB or are stored encrypted.
NEON_API_KEY=
DATABASE_ENCRYPTION_KEY=

# Realtime worker — public URL of the realtime-worker and a shared secret
# used to authorise /publish/* calls (replaces the old service binding).
REALTIME_WORKER_URL=https://realtime-test.weldsuite.org
REALTIME_INTERNAL_SECRET=replace_with_long_random_string

# Public realtime URL used by the support inbox WebSocket client
NEXT_PUBLIC_REALTIME_URL=wss://realtime-test.weldsuite.org
