# Master database (workspace routing)
MASTER_DATABASE_URL=postgresql://user:password@host/master_db?sslmode=require

# Neon API key (fallback for resolving tenant database URLs)
NEON_API_KEY=neon_api_key_here

# Encryption key for decrypting stored database URLs (64-char hex, AES-256)
DATABASE_ENCRYPTION_KEY=your_64_char_hex_key_here

# Resend API key (for sending booking confirmation emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
