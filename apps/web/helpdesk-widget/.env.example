# Helpdesk Widget Environment Configuration
# Copy this file to .env.local and fill in the values

# =============================================================================
# Widget API Configuration (REQUIRED)
# =============================================================================

# Widget API URL - handles all widget operations:
# - Widget configuration: GET /api/config
# - Conversations: GET/POST /api/conversations
# - Messages: GET/POST /api/messages/:conversationId
# - Agents status: GET /api/agents/status
# - Realtime tokens: POST /api/realtime/token
# - Articles: GET /api/articles
# - Folders: GET /api/folders
#
# Development: http://localhost:8787
# Test: https://helpdesk-widget-api-test.weldsuite.org
# Production: https://helpdesk-widget-api.weldsuite.org
VITE_WIDGET_API_URL=http://localhost:8787

# API Worker URL (optional - can be same as Widget API URL)
VITE_API_WORKER_URL=http://localhost:8787

# =============================================================================
# Sentry Error Reporting
# =============================================================================

# Sentry DSN for error reporting (required for production)
# Get this from your Sentry project settings
VITE_SENTRY_DSN=

# =============================================================================
# Widget Defaults
# =============================================================================

# Default widget ID for development/testing
VITE_DEFAULT_WIDGET_ID=

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug logging (optional)
VITE_DEBUG=false
