# Cloudflare Pages cache rules for the platform SPA.
# Copied verbatim into dist/ by Vite (public/ assets ship as-is).

# Content-hashed build output (e.g. /assets/index-DFsOehJK.js). The filename
# changes whenever the bytes change, so it is safe to cache forever. This is
# what lets the browser keep the current build's chunks while it revalidates
# the entry HTML below.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The entry document maps every request to the current build's hashed chunks.
# It MUST be revalidated on each load — otherwise a stale index.html keeps
# pointing tabs at chunk hashes a redeploy already deleted (the "Failed to
# fetch dynamically imported module" / wrong-MIME error).
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Runtime environment shim — not content-hashed, must never be cached.
/__ENV.js
  Cache-Control: no-cache
