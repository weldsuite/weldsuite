# ==============================================================================
# WeldSuite Platform - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to version control

# ==============================================================================
# Keycloak & NextAuth Configuration
# ==============================================================================
# Get these values from your Keycloak admin console
# Realm Settings > Clients > Your Client

# Keycloak Client ID (e.g., weldsuite-platform)
KEYCLOAK_ID=weldsuite-platform

# Keycloak Client Secret (from Clients > Your Client > Credentials tab)
# IMPORTANT: Keep this secure, never commit to git
KEYCLOAK_SECRET=your_client_secret

# Keycloak Issuer URL (format: http://your-keycloak-server:port/realms/your-realm)
# Example: http://localhost:8080/realms/weldsuite
# Example (prod): https://auth.yourdomain.com/realms/weldsuite
KEYCLOAK_ISSUER=http://localhost:8080/realms/weldsuite

# NextAuth Secret for session encryption (generate with: openssl rand -base64 32)
# IMPORTANT: Must be at least 32 characters long
AUTH_SECRET=generate_a_random_32_character_secret

# NextAuth Base URL (where your app is hosted)
# Example (dev): http://localhost:3000
# Example (prod): https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Application base URL
APP_BASE_URL=http://localhost:3000

# ==============================================================================
# API Configuration
# ==============================================================================

# Unified API endpoint for backend services
UNIFIED_API_URL=https://your-api-domain.com

# Internal API Worker URL (Cloudflare Worker for heavy operations)
# Development: http://localhost:8787
# Production: Uses internal service binding
API_WORKER_URL=http://localhost:8787

# External API endpoint (for public API access, scope discovery, etc.)
EXTERNAL_API_URL=https://external-api.your-domain.com

# Widget API URL (publicly accessible)
VITE_WIDGET_API_URL=https://widget.your-domain.com

# App URL (required for OAuth callbacks)
VITE_APP_URL=http://localhost:3000

# Booking Portal URL (for weldcalendar booking page links)
VITE_BOOKING_PORTAL_URL=http://localhost:3019

# ==============================================================================
# Analytics
# ==============================================================================

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
# Get your ID from: https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel Project Token
# Get your token from: https://mixpanel.com/settings/project
VITE_MIXPANEL_TOKEN=

# ==============================================================================
# Environment
# ==============================================================================
# Optional explicit environment override. Defaults to "production" when the
# Vite build is in PROD, "development" otherwise. Set to "test" / "preview"
# in the corresponding deploy environments.
VITE_ENVIRONMENT=

# ==============================================================================
# Real-time Event System (Cloudflare Durable Objects)
# ==============================================================================

# WebSocket URL for the realtime-worker
# Development: ws://localhost:8790/ws
# Test: wss://weldsuite-realtime-test.weldsuite.org/ws
# Production: wss://weldsuite-realtime-production.weldsuite.org/ws
VITE_REALTIME_URL=ws://localhost:8790/ws

# ==============================================================================
# Third-party Integrations
# ==============================================================================

# Stripe Configuration (for domain purchases and payments)
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Exact Online OAuth2 Configuration
# Register your app at: https://apps.exactonline.com/
EXACTONLINE_CLIENT_ID=your_exactonline_client_id
EXACTONLINE_CLIENT_SECRET=your_exactonline_client_secret
EXACTONLINE_REDIRECT_URI=http://localhost:3000/api/integrations/exactonline/callback

# For production, use your production URL:
# EXACTONLINE_REDIRECT_URI=https://yourdomain.com/api/integrations/exactonline/callback

# WooCommerce Configuration (Optional)
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxx
# WOOCOMMERCE_STORE_URL=https://yourstore.com

# ==============================================================================
# Development Settings
# ==============================================================================

# Enable development permission bypass (ONLY for local development)
# WARNING: This bypasses ALL permission checks
# ⚠️ ONLY set to 'true' in local development with NODE_ENV=development
# ⚠️ NEVER enable this in staging or production environments
# ⚠️ The app will log a security warning if this is enabled
# ENABLE_DEV_PERMISSION_BYPASS=true

# WARNING: The following setting disables SSL certificate validation
# ⚠️ ONLY use this in local development with self-signed certificates
# ⚠️ NEVER set this in staging or production environments
# ⚠️ This creates a major security vulnerability by making the app susceptible to MITM attacks
# Uncomment ONLY if you absolutely need it for local development:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ==============================================================================
# Mail Configuration (Mailcow)
# ==============================================================================

# Mailcow IMAP/SMTP Host
MAILCOW_HOST=mail.yourdomain.com

# Mail Credential Encryption Key (REQUIRED for OAuth mail accounts)
# Used to encrypt OAuth tokens (Gmail, Outlook) and SMTP passwords at rest
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be exactly 32 bytes (44 characters when base64 encoded)
MAIL_CREDENTIAL_ENCRYPTION_KEY=

# Mailcow Webhook Secret (for receiving new email notifications)
# Generate with: openssl rand -hex 32
# Must match the WELDSUITE_WEBHOOK_SECRET configured in Mailcow
MAILCOW_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Comma-separated list of IPs allowed to send webhooks
# Leave empty to allow all IPs (use signature verification for security)
MAILCOW_WEBHOOK_IPS=

# ==============================================================================
# IMPORTANT SECURITY NOTES
# ==============================================================================
# 1. NEVER commit your actual .env file to version control
# 2. Add .env to your .gitignore file
# 3. Rotate all credentials immediately if accidentally exposed
# 4. Use different credentials for development, staging, and production
# 5. Keep KEYCLOAK_SECRET and AUTH_SECRET secure
# 6. Generate AUTH_SECRET with: openssl rand -base64 32
# 7. Review Keycloak logs regularly for suspicious activity
# 8. Use environment-specific values (dev, staging, prod)
# 9. Never use NODE_TLS_REJECT_UNAUTHORIZED=0 outside of local development
# 10. Store production secrets in your deployment platform's secret management
#     (e.g., Vercel Environment Variables, AWS Secrets Manager, etc.)
# 11. Configure Keycloak redirect URIs to match your application URLs
# 12. Enable HTTPS in production for secure token transmission
