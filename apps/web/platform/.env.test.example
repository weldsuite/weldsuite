# E2E (Playwright) test environment — copy to .env.test and fill in.
# NEVER commit the real .env.test (contains a Clerk secret key and test-user credentials).
BASE_URL=http://localhost:3000
TEST_API_URL=http://localhost:8787

VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
VITE_CLERK_SIGN_IN_URL=/auth/sign-in
VITE_CLERK_SIGN_UP_URL=/auth/sign-up
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

TEST_USER_EMAIL=e2e@example.com
TEST_USER_PASSWORD=your-test-user-password
TEST_USER_ID=user_xxx
TEST_USER_NAME=E2E Test User
TEST_WORKSPACE_ID=ws_xxx
TEST_FIXTURES_TOKEN=your-fixtures-token
