{
  "name": "workflow-worker",
  "license": "AGPL-3.0-only",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:test": "wrangler deploy --env test",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.1",
    "@weldsuite/ai": "workspace:*",
    "@weldsuite/credits": "workspace:*",
    "@weldsuite/db": "workspace:*",
    "@weldsuite/entity-events": "workspace:*",
    "@weldsuite/workflow-integrations": "workspace:*",
    "@weldsuite/realtime": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250110.0",
    "@electric-sql/pglite": "^0.4.5",
    "@types/node": "^20",
    "typescript": "^5.7",
    "vitest": "^2.1.8",
    "wrangler": "^4.95.0"
  }
}
