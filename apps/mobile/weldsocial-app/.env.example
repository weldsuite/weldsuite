# API Configuration — unified app-api (also used for push-token registration)
EXPO_PUBLIC_APP_API_URL=https://app-api-test.weldsuite.org

# Realtime WebSocket
EXPO_PUBLIC_REALTIME_URL=wss://realtime-test.weldsuite.org

# Clerk Configuration
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# EAS project id (same value as `expo.extra.eas.projectId` in app.json)
EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
