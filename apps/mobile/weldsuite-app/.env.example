# API Configuration
# The app talks to the unified app-api (apps/workers/app-api).
# For local development run `pnpm dev` in apps/workers/app-api (wrangler, port 8789).
# For production builds this is set per-profile in eas.json.
EXPO_PUBLIC_APP_API_URL=http://localhost:8789

# Clerk Configuration
# Get this value from your Clerk Dashboard
# 1. Go to https://dashboard.clerk.com
# 2. Select your application
# 3. Go to API Keys and copy the Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Mixpanel Configuration
# Get your token from: https://mixpanel.com/settings/project
EXPO_PUBLIC_MIXPANEL_TOKEN=

# Example for local development with a real device (use your computer's LAN IP):
# EXPO_PUBLIC_APP_API_URL=http://192.168.1.100:8789
