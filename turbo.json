{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "BASE_URL",
    "CF_ACCOUNT_ID",
    "CF_REALTIME_APP_ID",
    "CF_REALTIME_APP_SECRET",
    "CI",
    "DATABASE_ENCRYPTION_KEY",
    "DATABASE_ENCRYPTION_KEY_V2",
    "DATABASE_URL",
    "DATABASE_URL_MASTER",
    "DEV",
    "HELPCENTER_API_URL",
    "MASTER_DATABASE_URL",
    "NEON_API_KEY",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_FIREBASE_API_KEY",
    "NEXT_PUBLIC_FIREBASE_APP_ID",
    "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
    "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID",
    "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
    "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET",
    "NODE_ENV",
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "PROD",
    "R2_ACCESS_KEY_ID",
    "R2_ACCOUNT_ID",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_URL",
    "R2_SECRET_ACCESS_KEY",
    "REALTIME_INTERNAL_SECRET",
    "REALTIME_WORKER_URL",
    "RESEND_API_KEY",
    "STRIPE_SECRET_KEY",
    "TELNYX_API_KEY",
    "TELNYX_CONNECTION_ID",
    "TELNYX_SIP_APP_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "AUTH0_DOMAIN",
        "AUTH0_ISSUER_BASE_URL",
        "AUTH0_CLIENT_ID",
        "AUTH0_CLIENT_SECRET",
        "AUTH0_SECRET",
        "AUTH0_BASE_URL",
        "AUTH0_AUDIENCE",
        "AUTH0_SCOPE",
        "APP_BASE_URL",
        "UNIFIED_API_URL",
        "NEXT_PUBLIC_SIGNALR_HUB_URL",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_WIDGET_POSITION",
        "NEXT_PUBLIC_WIDGET_THEME",
        "BACKEND_API_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**", "coverage/**"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "../../packages/design/ui/src/**"]
    }
  }
}
